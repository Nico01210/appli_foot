# Configuration automatisation des scores
AUTO_SCORE_UPDATE=false

# Clé API Football Data (gratuite: https://football-data.org)
FOOTBALL_API_KEY=your_api_key_here

# Configuration JWT (existant)
JWT_SECRET=your_jwt_secret_here

# Configuration base de données
DB_PATH=./football_predictions.db

# Environnement
NODE_ENV=development

# Port du serveur
PORT=3001

# Configuration CORS
CORS_ORIGIN=http://localhost:3001